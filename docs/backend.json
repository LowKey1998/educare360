
{
  "entities": {
    "Admission": {
      "title": "Admission",
      "description": "A student application for enrollment.",
      "type": "object",
      "properties": {
        "studentName": { "type": "string" },
        "grade": { "type": "string" },
        "age": { "type": "number" },
        "status": { "type": "string", "enum": ["New", "Under Review", "Interview", "Accepted", "Waitlisted", "Rejected"] },
        "submissionDate": { "type": "string" },
        "docsPending": { "type": "boolean" },
        "applicationId": { "type": "string" }
      }
    },
    "Student": {
      "title": "Student",
      "description": "A registered pupil in the school system.",
      "type": "object",
      "properties": {
        "admissionNo": { "type": "string" },
        "studentName": { "type": "string" },
        "grade": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "guardianName": { "type": "string" },
        "guardianPhone": { "type": "string" },
        "parentEmail": { "type": "string", "format": "email" },
        "feeBalance": { "type": "number" },
        "attendanceRate": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "School": {
      "title": "School",
      "description": "An educational institution or branch on the platform.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "city": { "type": "string" },
        "type": { "type": "string", "enum": ["Main Campus", "Branch", "Satellite"] },
        "enrollment": { "type": "number" },
        "staff": { "type": "number" },
        "plan": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "PlatformUser": {
      "title": "PlatformUser",
      "description": "A registered account with role-based access.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff", "parent"] },
        "createdAt": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/schools/{schoolId}": {
      "schema": "#/backend/entities/School",
      "description": "Directory of all schools managed on the platform."
    },
    "/users/{userId}": {
      "schema": "#/backend/entities/PlatformUser",
      "description": "System users and their institutional roles."
    }
  }
}
